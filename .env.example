# Safe template only. Copy to .env.local when Supabase is connected later.
# Put real project values in .env.local or Vercel environment variables, never here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analytics placeholders only. Use true/false in .env.local or Vercel after consent and tracking are approved.
NEXT_PUBLIC_ANALYTICS_ENABLED=
NEXT_PUBLIC_ANALYTICS_DEBUG=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Error monitoring placeholders only. SENTRY_AUTH_TOKEN is secret and must not be exposed to browser code.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

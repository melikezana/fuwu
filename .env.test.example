# Copy to .env.test for local e2e runs.
# Use a local Supabase instance or a dedicated test project only.
# Never point Playwright tests at production data.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
E2E_ALLOW_REMOTE_SUPABASE_TESTS=false

# Optional test identities. The tests skip live Supabase scenarios unless these are set.
E2E_CUSTOMER_EMAIL=customer.e2e@example.com
E2E_CUSTOMER_PHONE=+905550000101
E2E_CUSTOMER_OTP=123456
E2E_PROVIDER_EMAIL=provider.e2e@example.com
E2E_PENDING_PROVIDER_EMAIL=pending-provider.e2e@example.com
E2E_ADMIN_EMAIL=admin.e2e@example.com
